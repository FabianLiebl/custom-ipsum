{
  "name": "Custom Ipsum",
  "description": "Lorem Ipsum extension",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/content.js"],
    "all_frames": true,
    "match_about_blank": true
  }],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/fallensquirrel_128.png"
  },
  "icons": {
    "16": "assets/fallensquirrel_16.png",
    "48": "assets/fallensquirrel_48.png",
    "128": "assets/fallensquirrel_128.png"
  }
}